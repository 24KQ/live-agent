{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://liveagent.local/schemas/phase15_golden_manifest.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "manifest_id",
    "manifest_version",
    "seed",
    "case_ids",
    "domain_counts",
    "case_digests",
    "dataset_digest",
    "artifact_digests",
    "schema_digest",
    "generator_digest",
    "rules_digest",
    "source_code_digest",
    "source_manifest_digests",
    "supersedes",
    "manifest_digest"
  ],
  "properties": {
    "manifest_id": {"const": "phase15-runtime-v1"},
    "manifest_version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "seed": {"type": "integer", "minimum": 0},
    "case_ids": {
      "type": "object",
      "additionalProperties": false,
      "required": ["development", "validation", "holdout"],
      "properties": {
        "development": {"type": "array", "minItems": 12, "maxItems": 12, "items": {"type": "string"}},
        "validation": {"type": "array", "minItems": 24, "maxItems": 24, "items": {"type": "string"}},
        "holdout": {"type": "array", "minItems": 12, "maxItems": 12, "items": {"type": "string"}}
      }
    },
    "domain_counts": {
      "type": "object",
      "additionalProperties": {"type": "integer", "minimum": 0},
      "required": ["RUNTIME_SKILL", "RUNTIME_PLAN", "RUNTIME_EVENT", "LIVE", "PREPARE", "REVIEW"]
    },
    "case_digests": {
      "type": "object",
      "minProperties": 48,
      "additionalProperties": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
    },
    "dataset_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "artifact_digests": {"type": "object", "additionalProperties": {"type": "string", "pattern": "^[0-9a-f]{64}$"}},
    "schema_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "generator_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "rules_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "source_code_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "source_manifest_digests": {
      "type": "object",
      "additionalProperties": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
      "required": ["phase13-v3", "phase14-human-support-v1"]
    },
    "supersedes": {"type": "array", "prefixItems": [{"const": "phase13-v3"}, {"const": "phase14-human-support-v1"}], "minItems": 2, "maxItems": 2},
    "manifest_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
  }
}
