# LiveAgent 本地开发环境变量示例。
# 复制为 `.env` 后填入你本机 Docker 中间件的真实值；`.env` 已被 `.gitignore` 忽略，不要提交。

# PostgreSQL 主库：用于直播状态、商品、记忆、审计和 checkpoint。
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me

# LangGraph checkpoint：默认启用严格 msgpack，降低反序列化风险。
LANGGRAPH_STRICT_MSGPACK=true

# Redis：用于幂等键、短期缓存和分布式锁。
REDIS_HOST=localhost
REDIS_PORT=6379

# Kafka：用于弹幕、库存、流量和内部指令事件。
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_DANMAKU=anchor.danmaku
KAFKA_TOPIC_INVENTORY=anchor.inventory
KAFKA_TOPIC_TRAFFIC=anchor.traffic
KAFKA_TOPIC_COMMAND=anchor.command

# MinIO：可选，用于长报告、大文件和上下文卸载。
MINIO_ENDPOINT=http://localhost:8900
MINIO_ACCESS_KEY=change_me
MINIO_SECRET_KEY=change_me
MINIO_BUCKET=live-agent

# pgAdmin / MySQL：可选，仅在你需要本地可视化或对比实验时填写。
PGADMIN_EMAIL=change_me@example.com
PGADMIN_PASSWORD=change_me
MYSQL_USER=root
MYSQL_PASSWORD=change_me

# Embedding API 配置（Phase 3C 语义记忆检索）
# 默认使用智谱（bigmodel）embedding-3 模型，2048 维。
# 如果用 OpenAI 或本地 sentence-transformers，替换 base-url、model 和 key 即可。
EMBEDDING_API_BASE_URL=https://open.bigmodel.cn/api/paas/v4
EMBEDDING_API_KEY=change_me
EMBEDDING_MODEL=embedding-3
EMBEDDING_EMBEDDINGS_PATH=/embeddings
EMBEDDING_DIMENSIONS=2048

# LLM API 配置（Phase 3E DeepSeek 手卡话术增强）
LLM_API_BASE_URL=https://api.deepseek.com
LLM_API_KEY=change_me
LLM_MODEL=deepseek-v4-flash
LLM_MAX_TOKENS=500
LLM_TEMPERATURE=0.3
LLM_TIMEOUT_SECONDS=15
